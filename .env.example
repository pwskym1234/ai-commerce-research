# LLM API 키 (절대 실제 값을 .env.example에 넣지 말 것)
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# 모델 버전 핀 (R3 재현성 룰)
OPENAI_MODEL_VERSION=gpt-4o-2024-08-06
GEMINI_MODEL_VERSION=gemini-1.5-pro-002
PERPLEXITY_MODEL_VERSION=llama-3.1-sonar-large-128k-online

# 실험 기본 설정
N_REPEAT_DEFAULT=20
SEED_BASE=42

# 네이버 검색 API (블로그/카페/뉴스/쇼핑 — H14 외부 증거 + 쿼리 풀 수집)
# 발급: developers.naver.com → 애플리케이션 등록 → "검색" 권한 체크
# 등록 시 웹 서비스 URL: http://localhost
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
