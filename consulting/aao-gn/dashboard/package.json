{
  "name": "geo-diagnostic-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "sync-brands": "[ -d ../brands ] && rsync -a --delete --exclude='_*' --exclude='.DS_Store' ../brands/ ./brands/ || echo 'no ../brands (likely Vercel build) — using bundled brands/'",
    "prebuild": "npm run sync-brands",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx scripts/generate-sample.ts",
    "deploy": "npm run sync-brands && vercel --prod --yes"
  },
  "dependencies": {
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "papaparse": "^5.4.1",
    "zod": "^3.23.8",
    "recharts": "^2.13.3",
    "pretendard": "^1.3.9"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/papaparse": "^5.3.15",
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "tsx": "^4.19.2"
  }
}
