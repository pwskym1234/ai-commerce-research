*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*-checkpoint.ipynb

# 데이터 — raw HTML이 너무 크면 외부 스토리지로
data/raw/**/*.html
data/raw/**/*.json
data/raw/**/*.csv
!data/raw/.gitkeep
!data/raw/**/sample_*

# 큰 모델 아티팩트
ml/models/*.pkl
ml/models/*.joblib
ml/models/*.bin
!ml/models/.gitkeep

# API 응답 (큰 jsonl)
experiments/api_runs/**/*.jsonl
!experiments/api_runs/.gitkeep
!experiments/api_runs/**/sample_*

# API 캐시 (sha256 키 단위) — 재실험 시 자동 재생성
experiments/api_runs/_cache/

